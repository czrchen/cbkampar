---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark">CB</span>
        <span class="brand-text">CB Kampar</span>
      </a>
      <p>A confectioner's collection from Kampar, Perak — traditional chicken biscuits, curry chicken bread, kaya puffs and fine delicacies.</p>
      <div class="socials">
        <a href="#" aria-label="Facebook">Facebook</a>
        <a href="#" aria-label="Instagram">Instagram</a>
        <a href="#" aria-label="WhatsApp">WhatsApp</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <a href="/">Home</a>
      <a href="/about">About Us</a>
      <a href="/products">Products</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Our Collection</h4>
      <a href="/products">Chicken Biscuits</a>
      <a href="/products">Curry Chicken Bread</a>
      <a href="/products">Kaya Puff</a>
      <a href="/products">Honey Sa Qi Ma</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <p class="muted">A Confectioner's Collection · Kampar, Perak, Malaysia</p>
      <a href="/contact">Send an enquiry →</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} CB Kampar · A Confectioner's Collection</span>
    <span>Kampar, Perak, Malaysia</span>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--navy);
    color: #E9D8C4;
    margin-top: 110px;
    padding: 70px 0 30px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1.4fr;
    gap: 40px;
  }
  .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .brand-mark { display: grid; place-items: center; width: 50px; height: 50px; background: var(--red); color: #fff; border-radius: 12px; font-family: var(--font-display); font-weight: 800; font-size: 1.3rem; }
  .brand-text { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; color: #fff; letter-spacing: -0.02em; }
  .footer-brand p { color: #C2A98E; max-width: 320px; font-size: .95rem; line-height: 1.6; }

  .socials { display: flex; gap: 18px; margin-top: 22px; }
  .socials a {
    font-size: .88rem; font-weight: 500; color: #C2A98E;
    transition: color .2s ease;
  }
  .socials a:hover { color: var(--gold); }

  .footer-col h4 {
    font-family: var(--font-display); font-size: .8rem; letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 18px; color: #A98C6E;
  }
  .footer-col a { display: block; color: #E9D8C4; padding: 6px 0; font-size: .95rem; transition: color .18s ease; }
  .footer-col a:hover { color: #fff; }
  .footer-col .muted { color: #C2A98E; margin-bottom: 14px; font-size: .95rem; line-height: 1.6; }

  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    margin-top: 54px; padding-top: 26px;
    border-top: 1px solid rgba(255,255,255,.08);
    color: #A98C6E; font-size: .86rem;
  }

  @media (max-width: 860px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; gap: 30px; }
  }
</style>
